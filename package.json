{
  "name": "ts500-pmm-wasm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:wasm": "node ./node_modules/assemblyscript/bin/asc.js assembly/index.ts --target release --optimize --outFile public/wasm/pmm.wasm",
    "dev": "npm run build:wasm && node ./node_modules/vite/bin/vite.js",
    "build": "npm run build:wasm && node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "devDependencies": {
    "@assemblyscript/loader": "^0.28.9",
    "assemblyscript": "^0.28.9",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "plotly.js-dist-min": "^3.4.0"
  }
}
